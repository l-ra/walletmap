<style is:global>
  .glossary-term-wrap {
    position: relative;
    display: inline;
    white-space: normal;
  }

  .glossary-abbr {
    font-style: normal;
    font-weight: 600;
    color: #8cb4ff;
    text-decoration: underline dotted rgba(140, 180, 255, 0.55);
    text-underline-offset: 3px;
    cursor: help;
    border: none;
    background: none;
    padding: 0;
    font-size: inherit;
    line-height: inherit;
  }

  .glossary-abbr:focus {
    outline: none;
  }

  .glossary-abbr:focus-visible {
    outline: 2px solid rgba(91, 141, 255, 0.75);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .glossary-tooltip {
    position: absolute;
    z-index: 40;
    left: 50%;
    bottom: calc(100% + 8px);
    transform: translateX(-50%) translateY(4px);
    min-width: 220px;
    max-width: min(320px, 85vw);
    padding: 10px 12px;
    border-radius: 10px;
    background: #151a2e;
    border: 1px solid rgba(140, 180, 255, 0.25);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
  }

  .glossary-tooltip__full {
    display: block;
    font-size: 0.82rem;
    line-height: 1.45;
    color: #e8edf5;
    margin-bottom: 8px;
  }

  .glossary-tooltip__more {
    display: inline-flex;
    align-items: center;
    font-size: 0.78rem;
    font-weight: 600;
    color: #8cb4ff;
    background: rgba(55, 125, 255, 0.12);
    border: 1px solid rgba(55, 125, 255, 0.25);
    border-radius: 999px;
    padding: 4px 10px;
    cursor: pointer;
    font-family: inherit;
  }

  .glossary-tooltip__more:hover {
    background: rgba(55, 125, 255, 0.2);
    color: #cfe4ff;
  }

  @media (hover: hover) and (pointer: fine) {
    .glossary-term-wrap:hover .glossary-tooltip,
    .glossary-term-wrap:focus-within .glossary-tooltip {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }
  }

  .glossary-term-wrap.is-tooltip-open .glossary-tooltip {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .glossary-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    border: none;
    background: transparent;
    max-width: none;
    max-height: none;
    width: 100%;
    height: 100%;
    margin: 0;
  }

  .glossary-modal[open] {
    display: flex;
  }

  .glossary-modal::backdrop {
    background: rgba(5, 8, 18, 0.72);
  }

  .glossary-modal__panel {
    position: relative;
    z-index: 1;
    width: min(640px, 100%);
    max-height: min(80vh, 720px);
    overflow: auto;
    padding: 28px 28px 24px;
    border-radius: 16px;
    background: #12162a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
  }

  .glossary-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: #c8d0e0;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
  }

  .glossary-modal__close:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }

  .glossary-modal__abbr {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #8cb4ff;
    margin-bottom: 8px;
  }

  .glossary-modal__title {
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
    line-height: 1.3;
    padding-right: 36px;
  }

  .glossary-modal__short {
    color: #c8d0e0;
    margin: 0 0 16px;
    line-height: 1.6;
  }

  .glossary-modal__long p {
    color: #aab4cc;
    margin: 0 0 12px;
    line-height: 1.65;
  }

  .glossary-modal__section-title {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #8892b0;
    margin: 20px 0 8px;
  }

  .glossary-modal__related {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .glossary-modal__related button {
    font-size: 0.82rem;
    font-weight: 600;
    color: #8cb4ff;
    background: rgba(55, 125, 255, 0.12);
    border: 1px solid rgba(55, 125, 255, 0.22);
    border-radius: 999px;
    padding: 5px 12px;
    cursor: pointer;
    font-family: inherit;
  }

  .glossary-modal__related button:hover {
    background: rgba(55, 125, 255, 0.22);
  }

  .glossary-modal__sources {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .glossary-modal__sources li {
    margin-bottom: 6px;
  }

  .glossary-modal__sources a {
    color: #9ec8ff;
    font-size: 0.92rem;
  }

  .glossary-index {
    margin-top: 8px;
  }

  .glossary-index__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 24px 0;
  }

  .glossary-index__filter {
    font-size: 0.78rem;
    font-weight: 600;
    color: #8892b0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    padding: 6px 12px;
    cursor: pointer;
    font-family: inherit;
  }

  .glossary-index__filter.is-active,
  .glossary-index__filter:hover {
    color: #8cb4ff;
    border-color: rgba(55, 125, 255, 0.35);
    background: rgba(55, 125, 255, 0.12);
  }

  .glossary-index__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .glossary-index__item {
    padding: 20px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .glossary-index__item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .glossary-index__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px 16px;
    margin-bottom: 8px;
  }

  .glossary-index__abbr {
    font-size: 1rem;
    font-weight: 800;
    color: #8cb4ff;
    letter-spacing: 0.03em;
  }

  .glossary-index__full {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }

  .glossary-index__desc {
    color: #aab4cc;
    margin: 0 0 10px;
    line-height: 1.6;
  }

  .glossary-index__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
  }

  .glossary-index__tag {
    font-size: 0.72rem;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: #8892b0;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .glossary-index__usage {
    font-size: 0.88rem;
    color: #8892b0;
    line-height: 1.55;
  }

  .glossary-index__usage a {
    color: #9ec8ff;
    white-space: nowrap;
  }

  .glossary-index__detail-btn {
    margin-top: 10px;
    font-size: 0.82rem;
    font-weight: 600;
    color: #8cb4ff;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 640px) {
    .glossary-modal {
      padding: 16px;
    }

    .glossary-modal__panel {
      padding: 22px 18px 18px;
    }

    .glossary-tooltip {
      left: 0;
      transform: translateY(4px);
      max-width: min(280px, 90vw);
    }

    .glossary-term-wrap.is-tooltip-open .glossary-tooltip,
    .glossary-term-wrap:hover .glossary-tooltip,
    .glossary-term-wrap:focus-within .glossary-tooltip {
      transform: translateY(0);
    }
  }
</style>
