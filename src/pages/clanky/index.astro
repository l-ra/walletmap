---
import { getCollection } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<ArticleLayout title="Články" description="Publikace o evropské digitální identitě">
  <h1>Články</h1>
  <p>Přehled publikací o EU Digital Identity Wallet, standardech a implementacích.</p>

  {articles.length === 0 ? (
    <p>Žádné články zatím nejsou publikované.</p>
  ) : (
    <ul>
      {articles.map((article) => (
        <li>
          <a href={`/clanky/${article.slug}`}>{article.data.title}</a>
          {' — '}
          <time datetime={article.data.pubDate.toISOString()}>
            {article.data.pubDate.toLocaleDateString('cs-CZ')}
          </time>
        </li>
      ))}
    </ul>
  )}
</ArticleLayout>
