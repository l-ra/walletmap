---
import { getCollection } from 'astro:content';
import ScenarioLayout from '../../../layouts/ScenarioLayout.astro';
import { SCENARIO_SERIES, categoryLabels, seriesBasePath } from '../../../lib/scenarios';

const scenarios = (
  await getCollection('scenarios', ({ data }) => !data.draft && data.series === SCENARIO_SERIES)
).sort((a, b) => a.data.order - b.data.order);

const grouped = Object.entries(categoryLabels)
  .map(([key, label]) => ({
    key,
    label,
    items: scenarios.filter((s) => s.data.category === key),
  }))
  .filter((g) => g.items.length > 0);
---

<ScenarioLayout
  title="Střelecký klub — modelový příklad"
  description="Přehledové scénáře použití evropské peněženky digitální identity ve střeleckém klubu."
  currentSlug=""
  scenarios={scenarios}
>
  <h1>Střelecký klub a evropská peněženka</h1>
  <p>
    Tato sekce popisuje modelový příklad střeleckého klubu, který využívá ekosystém
    <strong>EU Digital Identity Wallet (EUDIW)</strong> pro členské průkazy, průkazy závodníků,
    startovní lístky a ověřování státních dokladů. Scénáře pokrývají pohled uživatele,
    vydavatele (klubu) i ověřovatele (střelnice, soutěže, stát).
  </p>

  <h2>Co scénáře demonstrují</h2>
  <ul>
    <li><strong>Uživatelskou zkušenost</strong> — žádost, přijetí a použití průkazů v peněžence</li>
    <li><strong>Úkoly vydavatele</strong> — klub vydává a spravuje vlastní potvrzení (OID4VCI)</li>
    <li><strong>Úkoly ověřovatele</strong> — klub, střelnice a soutěže přijímají průkazy (OID4VP)</li>
    <li><strong>Státní doklady</strong> — PID, zbrojní oprávnění a průkaz zbraně od státu</li>
  </ul>

  <h2>Role v modelu</h2>
  <table>
    <thead>
      <tr>
        <th>Role</th>
        <th>Popis</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>Řadový člen</td><td>Člen klubu s ročním členstvím</td></tr>
      <tr><td>Člen výboru</td><td>Schvaluje vydání a změny členských průkazů</td></tr>
      <tr><td>Předseda výboru</td><td>Schvaluje vydání samostatně nebo s dalším členem výboru</td></tr>
      <tr><td>Správce střelnice</td><td>Přístup do zázemí, správa provozu střelnice</td></tr>
      <tr><td>Rozhodčí</td><td>Ověřuje závodníky a startovní lístky na soutěži</td></tr>
      <tr><td>Závodník</td><td>Registrovaný soutěžící se zbrojním oprávněním</td></tr>
      <tr><td>Klub (vydavatel)</td><td>Vydává členské průkazy, průkazy závodníků a startovní lístky</td></tr>
      <tr><td>Stát (vydavatel)</td><td>Vydává PID, zbrojní oprávnění a průkaz zbraně</td></tr>
    </tbody>
  </table>

  <h2>Průkazy v peněžence</h2>
  <table>
    <thead>
      <tr>
        <th>Průkaz</th>
        <th>Vydavatel</th>
        <th>Platnost</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>Klubový průkaz</td><td>Střelecký klub</td><td>Roční, automatická obnova (background refresh)</td></tr>
      <tr><td>Průkaz závodníka</td><td>Střelecký klub</td><td>Sezónní, automatické prodloužení po 3 závodech</td></tr>
      <tr><td>Startovní lístek</td><td>Střelecký klub</td><td>Po dobu konkrétní soutěže</td></tr>
      <tr><td>PID</td><td>Stát</td><td>Dle státní politiky</td></tr>
      <tr><td>Zbrojní oprávnění</td><td>Stát</td><td>Dle zákona</td></tr>
      <tr><td>Průkaz zbraně / povolení</td><td>Stát</td><td>Dle zákona</td></tr>
    </tbody>
  </table>

  <h2>Scénáře podle oblasti</h2>
  {
    grouped.map((group) => (
      <>
        <h3>{group.label}</h3>
        <ul>
          {group.items.map((item) => (
            <li>
              <a href={`${seriesBasePath}/${item.slug}`}>{item.data.title}</a>
              {' — '}
              {item.data.description}
            </li>
          ))}
        </ul>
      </>
    ))
  }

  <p>
    Doporučený postup: začněte scénářem
    <a href={`${seriesBasePath}/prehled-modelu`}>Přehled modelu</a>
    a pokračujte dle navigačního menu vlevo.
  </p>
</ScenarioLayout>
