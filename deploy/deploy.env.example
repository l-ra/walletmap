# Šablona konfigurace pro publikaci
#
# Zkopírujte tento soubor a doplňte vlastní hodnoty:
#   cp deploy/deploy.env.example deploy/deploy.env
#
# Soubor deploy/deploy.env je v .gitignore a necommituje se.
# Pokud soubor neexistuje, skript použije proměnné prostředí (vhodné pro CI/CD).
#
# Vlastní cestu k souboru lze předat proměnnou prostředí:
#   WALLETMAP_DEPLOY_ENV=/cesta/k/jiny.env npm run deploy

# Cílový server (SSH hostname nebo IP)
DEPLOY_HOST=staticka-stranka.example.org

# SSH uživatel (volitelné — pokud prázdné, použije se výchozí z ~/.ssh/config)
# DEPLOY_USER=deploybot

# Cílová složka na serveru (DocumentRoot pro Apache httpd)
DEPLOY_PATH=/var/www/vhosts/kralovstvi-ponozek/htdocs

# Volitelné: vlastní SSH příkaz pro rsync (např. jiný port nebo klíč)
# RSYNC_SSH="ssh -p 2222 -i ~/.ssh/deploy_key"

# Volitelné: další parametry rsync
# RSYNC_EXTRA_OPTS="--chmod=Du=rwx,Dgo=rx,Fu=rw,Fgo=r"
